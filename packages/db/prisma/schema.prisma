// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String @id @default(uuid())
  clerkId String @unique
  name    String
  email   String @unique
  level   Int    @default(1)
  totalXP Int    @default(0)

  // Stored as IANA timezone string e.g. "Asia/Kolkata"
  // Used by the EOD scheduler to run consequence checks at the right local time
  timezone String

  // OAuth2 tokens for Twitter/X shame posts — stored encrypted, never in plaintext
  // Null until the user connects their Twitter account
  twitterTokens Json?

  createdAt DateTime @default(now())

  // Relations — a user owns many pacts and XP log entries
  pacts  Pact[]
  xpLogs XPLog[]

  @@index([clerkId])
  @@map("users")
}

model Pact {
  id          String    @id @default(uuid())
  userId      String
  name        String
  description String?
  frequency   Frequency

  // Only set when frequency is WEEKLY — e.g. 3 means "3 times per week"
  weeklyTarget Int?

  // Immutable after creation — users cannot downgrade their stakes mid-streak
  // This is a core product rule, not a technical constraint
  consequenceTier Int

  graceDaysAllowed Int @default(0)
  graceDaysUsed    Int @default(0)

  startDate DateTime
  endDate   DateTime? // null means infinite pact

  status    PactStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns    CheckIn[]
  streak      Streak?      // one streak record per pact
  consequence Consequence? // one consequence config per pact
  graceDays   GraceDay[]

  @@index([userId, status]) // most common query: get all active pacts for a user
  @@map("pacts")
}

// ============================================================
// CHECK-IN
// ============================================================

model CheckIn {
  id     String @id @default(uuid())
  pactId String
  userId String

  // Stored as UTC midnight — timezone conversion happens at query time
  // Never store local time in the DB — always UTC
  date String

  // Optional proof — photo URL, link, or note attached to the check-in
  proof String?

  // XP is calculated and frozen at check-in time based on current streak
  // Not recalculated later — what you earned stays earned
  xpEarned Int

  createdAt DateTime @default(now())

  pact Pact @relation(fields: [pactId], references: [id], onDelete: Cascade)

  // Prevents duplicate check-ins for the same pact on the same day
  @@unique([pactId, date])
  @@index([pactId, date])
  @@map("check_ins")
}

// ============================================================
// STREAK
// ============================================================

model Streak {
  id     String @id @default(uuid())
  pactId String @unique

  currentStreak Int   @default(0)
  longestStreak Int   @default(0)

  // Multiplier resets on a missed day but level does not
  // Increases at 7-day and 30-day milestones per STREAK_MULTIPLIERS in @aion/shared
  multiplier Float @default(1.0)

  // Null until the first check-in — used to detect missed days
  lastCheckInDate String?

  pact Pact @relation(fields: [pactId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

// ============================================================
// CONSEQUENCE
// ============================================================

model Consequence {
  id     String @id @default(uuid())
  pactId String @unique

  type   ConsequenceType
  status ConsequenceStatus @default(ARMED)

  // JSON blob — structure varies by tier:
  // Tier 1: { shameTemplate: string }
  // Tier 2: { lockDurationMinutes: number }
  // Tier 3: { amountINR: number, ngoId: string }
  // Tier 4: all of the above combined
  config Json

  // Populated only for Tier 3 and 4 — pre-authorized at pact creation
  razorpayMandateId String?

  // Timestamp of when the consequence was executed
  firedAt DateTime?

  pact Pact @relation(fields: [pactId], references: [id], onDelete: Cascade)

  @@map("consequences")
}

// ============================================================
// GRACE DAY
// ============================================================

model GraceDay {
  id     String @id @default(uuid())
  pactId String

  // Date the grace day was consumed — stored as YYYY-MM-DD string in user's timezone
  date   String

  // Optional reason the user provides — shown in history
  reason String?

  pact Pact @relation(fields: [pactId], references: [id], onDelete: Cascade)

  // Prevents deducting two grace days for the same missed day
  @@unique([pactId, date])
  @@map("grace_days")
}

// ============================================================
// XP LOG
// ============================================================

model XPLog {
  id     String   @id @default(uuid())
  userId String
  amount Int
  source XPSource

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_logs")
}

// ============================================================
// ENUMS
// ============================================================

enum Frequency {
  DAILY
  WEEKLY
}

enum PactStatus {
  ACTIVE
  COMPLETED
  FAILED
  PAUSED
}

enum ConsequenceType {
  SHAME
  LOCK
  FINANCIAL
  NUCLEAR
}

enum ConsequenceStatus {
  ARMED
  FIRED
  SKIPPED_GRACE
  DEBT
  DISARMED
}

enum XPSource {
  CHECKIN
  PACT_COMPLETE
  MILESTONE
  BONUS
}

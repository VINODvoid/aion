{
  "name": "aion",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd packages/api dev",
    "dev:queue": "bun run --cwd packages/queue dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:generate": "bun run --cwd packages/db generate",
    "db:studio": "bun run --cwd packages/db studio",
    "db:seed": "bun run --cwd packages/db seed",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test",
    "build": "bun run --filter '*' build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
